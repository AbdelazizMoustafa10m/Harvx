class Documented:
    """A class with comprehensive documentation.

    This class demonstrates various docstring patterns
    used in Python code.

    Attributes:
        name: The name of the instance.
        value: An integer value.
    """

    def __init__(self, name: str, value: int = 0) -> None:
        """Initialize the Documented instance.

        Args:
            name: The name for this instance.
            value: An optional integer value.
        """

    def method_with_docstring(self) -> str:
        """Return the string representation."""

    def method_without_docstring(self) -> int:

    def method_multiline_docstring(self, factor: int) -> int:
