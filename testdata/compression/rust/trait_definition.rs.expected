/// A connection trait for managing network connections.
pub trait Connection: Send + Sync {
    /// The error type for this connection.
    type Error;
    /// The configuration type.
    type Config: Default;
    /// Connect to the given address.
    fn connect(addr: &str) -> Result<Self, Self::Error> where Self: Sized;
    /// Check if the connection is alive.
    fn is_alive(&self) -> bool;
    /// Close the connection gracefully.
    fn close(&mut self) -> Result<(), Self::Error>;
    /// Ping with a default implementation.
    fn ping(&self) -> bool
}

/// A simple logging trait.
pub trait Logger {
    fn log(&self, msg: &str);
    /// Debug logs a message with DEBUG prefix.
    fn debug(&self, msg: &str)
    /// Info logs a message with INFO prefix.
    fn info(&self, msg: &str)
}

/// A handler trait with supertraits and lifetime.
pub trait Handler<'a>: Send + Sync + 'static {
    fn handle(&self, req: &'a Request) -> Response;
}

/// An unsafe trait for raw pointer operations.
pub unsafe trait RawAccess {
    fn raw_ptr(&self) -> *const u8;
}